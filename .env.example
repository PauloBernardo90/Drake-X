# Drake-X environment configuration example.
# Copy to `.env` and adjust as needed. All values are optional; sensible defaults
# are provided in code.

# Path to the SQLite database used for sessions/results.
DRAKE_X_DB_PATH=./drake_x.db

# Directory where raw outputs, normalized artifacts, and reports are written.
DRAKE_X_OUTPUT_DIR=./drake_x_runs

# Default recon profile (passive | safe | web-basic | network-basic).
DRAKE_X_PROFILE=safe

# Per-tool execution timeout in seconds.
DRAKE_X_TIMEOUT=180

# Local Ollama base URL. Drake-X never calls remote AI providers.
DRAKE_X_OLLAMA_URL=http://localhost:11434

# Default Ollama model. Pick something light by default.
DRAKE_X_OLLAMA_MODEL=llama3.2:3b

# Set to "1" to disable AI analysis by default even when Ollama is reachable.
DRAKE_X_DISABLE_AI=0
